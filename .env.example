# ===========================================================================
# .env.example  —  TEMPLATE for local development secrets.
#
# HOW TO USE:
#   1. Copy this file:           cp .env.example .env
#   2. Fill in the real values   (you'll get these in Phase 1 once Azure +
#                                 Snowflake accounts exist).
#   3. NEVER commit .env         (it's in .gitignore).
#
# IN PRODUCTION: none of these live in a file. Azure Data Factory pulls them
# from Azure Key Vault at runtime and passes them to the extractors/dbt.
# This .env file exists ONLY so you can run things on your laptop.
# ===========================================================================

# --- Snowflake (warehouse, hosted on Azure / East US 2) ---
# SF_ACCOUNT is the account identifier from your Snowflake URL.
# Example: abc12345.east-us-2.azure  (the part before .snowflakecomputing.com)
SF_ACCOUNT=your_account.east-us-2.azure
SF_USER=your_user
SF_PASSWORD=your_password
SF_DATABASE=MACROMARKET
# The extractor/loader connects as LOADER (Bronze write only). dbt overrides
# this with TRANSFORMER; the MCP server overrides with REPORTER.
SF_WAREHOUSE=LOADER_WH
SF_ROLE=LOADER

# --- ADLS Gen2 (raw data landing zone) ---
AZURE_STORAGE_ACCOUNT_NAME=macromarketelt
AZURE_STORAGE_ACCOUNT_KEY=your_key
# Connection string is the easiest way for the Python uploader to authenticate.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=macromarketelt;AccountKey=...;EndpointSuffix=core.windows.net

# --- FRED API (macroeconomic data) ---
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# --- Databricks (sentiment enrichment, used in Phase 5) ---
DATABRICKS_HOST=https://adb-xxxxxxx.azuredatabricks.net
DATABRICKS_TOKEN=your_token

# --- MCP Server (read-only Gold access, used in Phase 6) ---
# The MCP server reuses SF_ACCOUNT/SF_USER/SF_PASSWORD but with a locked-down role.
MCP_SF_ROLE=REPORTER
MCP_SF_WAREHOUSE=REPORTER_WH
