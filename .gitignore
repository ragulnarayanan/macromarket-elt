# ---------------------------------------------------------------------------
# .gitignore — files git must NEVER track.
# The #1 job of this file: keep secrets and generated junk out of the repo.
# ---------------------------------------------------------------------------

# --- Secrets (NEVER commit these) ---
# real local secrets live in .env (ignored); only .env.example is committed.
.env
*.pem
*.key
**/secrets/
# locally-filled SQL copies that contain a real SAS token (e.g.
# 06_adls_external_stage.local.sql). Committed *.sql files keep placeholders.
**/*.local.sql

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# --- dbt (all generated at build time, never source) ---
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/logs/
.user.yml

# --- Local data files (raw extracts staged before upload) ---
data/
*.json.tmp
extractors/output/

# --- OS / editor cruft ---
.DS_Store
.idea/
.vscode/
*.swp
